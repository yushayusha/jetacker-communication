<?xml version='1.0' encoding='UTF-8'?>
<StateMachine name="Challenge1FSM" outcomes="Complete Abort" start_state="Initialize Params">
  <State name="Initialize Params" type="py" module="telemetry_package.challenge_one_fsm" class="InitializeParams">
    <Transition from="success" to="Launch UAV"/>
    <Transition from="failure" to="Initialize Params"/>
  </State>
  <State name="Launch UAV" type="py" module="telemetry_package.challenge_one_fsm" class="BeginUAVLaunch">
    <Transition from="success" to="Start UGV Movement"/>
    <Transition from="failure" to="Abort"/>
  </State>
  <State name="Start UGV Movement" type="py" module="telemetry_package.challenge_one_fsm" class="BeginUGVMovement">
    <Transition from="success" to="UAV Detecting UGV"/>
    <Transition from="failure" to="Abort"/>
  </State>
  <State name="UAV Detecting UGV" type="py" module="telemetry_package.challenge_one_fsm" class="BeginUGVDetection">
    <Transition from="success" to="UAV Landing on UGV"/>
    <Transition from="failure" to="UAV Detecting UGV"/>
  </State>
  <State name="UAV Landing on UGV" type="py" module="telemetry_package.challenge_one_fsm" class="BeginUAVLanding">
    <Transition from="success" to="UAV UGV Continues Movement"/>
    <Transition from="failure" to="Abort"/>
  </State>
  <State name="UAV UGV Continues Movement" type="py" module="telemetry_package.challenge_one_fsm" class="BeginUAVUGVMovement">
    <Transition from="failure" to="UAV UGV Continues Movement"/>
    <Transition from="success" to="Complete"/>
  </State>
</StateMachine>
